  "keyFeatures": [
    "ARMv8 CPU emulation with ARMeilleure JIT compiler",
    "Maxwell GPU emulation with OpenGL, Vulkan, and Metal support",
    "HLE (High-Level Emulation) of Nintendo Switch OS services",
    "Resolution scaling and graphics enhancements (FXAA, FSR, anisotropic filtering)",
    "Profiled Persistent Translation Cache (PTC) for faster load times",
    "Multiple audio backends (SDL3, OpenAL, libsoundio)",
    "Full controller support including Joy-Con and motion controls",
    "DLC and mod support with runtime patches"
  ],
  "publicApiSurface": [
    "ARMeilleure (CPU emulator/JIT compiler)",
    "Ryujinx.Graphics.Gpu (GPU context and command processing)",
    "Ryujinx.Graphics.OpenGL (OpenGL graphics backend)",
    "Ryujinx.Graphics.Vulkan (Vulkan graphics backend)",
    "Ryujinx.HLE (High-Level Emulation layer)",
    "Ryujinx.Audio (Audio processing)",
    "Ryujinx.Input (Input handling)",
    "Ryujinx.Memory (Memory management)",
    "Ryujinx.Horizon (Horizon OS implementation)",
    "Switch class (Main emulator context)"
  ]
